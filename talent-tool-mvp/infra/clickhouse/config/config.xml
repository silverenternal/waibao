<?xml version="1.0"?>
<!--
  T2801 ClickHouse 主配置
  - 启用远程 server 监听 (inter-server replication 必需)
  - 启用 Macros (让 SQL 引用 {shard}, {replica} 占位符)
  - 启用 Zookeeper 协调副本
-->
<clickhouse>
    <logger>
        <level>warning</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>1000M</size>
        <count>10</count>
    </logger>

    <display_name>waibao-warehouse</display_name>
    <timezone>UTC</timezone>

    <listen_host>0.0.0.0</listen_host>
    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    <interserver_http_port>9009</interserver_http_port>
    <max_connections>4096</max_connections>
    <keep_alive_timeout>3</keep_alive_timeout>
    <max_concurrent_queries>200</max_concurrent_queries>
    <uncompressed_cache_size>1073741824</uncompressed_cache_size>
    <mark_cache_size>1073741824</mark_cache_size>
    <path>/var/lib/clickhouse/</path>
    <tmp_path>/var/lib/clickhouse/tmp/</tmp_path>

    <user_files_path>/var/lib/clickhouse/user_files/</user_files_path>
    <user_directories>
        <users_xml>
            <path>/etc/clickhouse-server/users.d</path>
        </users_xml>
    </user_directories>

    <default_profile>default</default_profile>
    <default_database>warehouse</default_database>

    <timezone>UTC</timezone>

    <remote_servers>
        <!--
          集群定义: 1 shard × 3 副本.
          生产环境可扩到 2+ shard (水平分片).
        -->
        <waibao_cluster>
            <secret>waibao_cluster_secret_change_me</secret>
            <shard>
                <internal_replication>true</internal_replication>
                <replica>
                    <host>clickhouse-shard1-replica1</host>
                    <port>9000</port>
                </replica>
                <replica>
                    <host>clickhouse-shard1-replica2</host>
                    <port>9000</port>
                </replica>
                <replica>
                    <host>clickhouse-shard1-replica3</host>
                    <port>9000</port>
                </replica>
            </shard>
        </waibao_cluster>
    </remote_servers>

    <zookeeper>
        <node>
            <host>zoo1</host>
            <port>2181</port>
        </node>
        <node>
            <host>zoo2</host>
            <port>2181</port>
        </node>
        <node>
            <host>zoo3</host>
            <port>2181</port>
        </node>
    </zookeeper>

    <macros>
        <!--
          这两个值每个节点不同, 用 macros/shard-1/*.xml 覆盖:
            ch-s1-r1 → shard 1, replica 1
            ch-s1-r2 → shard 1, replica 2
            ch-s1-r3 → shard 1, replica 3
        -->
        <shard>1</shard>
        <replica>1</replica>
    </macros>

    <distributed_ddl>
        <path>/clickhouse/waibao_cluster/ddl</path>
    </distributed_ddl>

    <merge_tree>
        <max_suspicious_broken_parts>5</max_suspicious_broken_parts>
    </merge_tree>

    <max_table_size_to_drop>0</max_table_size_to_drop>
    <max_partition_size_to_drop>0</max_partition_size_to_drop>

    <!--
      备份: 启用 S3 备份
      见 storage.xml + backup.xml
    -->

    <openSSL>
        <server>
            <defaultSessionTimeout>600</defaultSessionTimeout>
        </server>
    </openSSL>

    <query_log>
        <database>system</database>
        <table>query_log</table>
        <engine>Engine = MergeTree PARTITION BY event_date ORDER BY event_time TTL event_date + INTERVAL 30 DAY</engine>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
    </query_log>
</clickhouse>
