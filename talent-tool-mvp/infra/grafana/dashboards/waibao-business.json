{
  "title": "Waibao Business",
  "uid": "waibao-business",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["waibao", "business"],
  "panels": [
    {
      "id": 1,
      "title": "Tickets created by priority",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (priority) (rate(tickets_created_total[5m]))",
          "legendFormat": "{{priority}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Matches computed by status",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (status) (rate(matches_computed_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active users (24h)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6},
      "targets": [{"expr": "active_users"}]
    },
    {
      "id": 4,
      "title": "Cache hit ratio",
      "type": "gauge",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 6},
      "targets": [{"expr": "llm_cache_hit_ratio"}]
    }
  ]
}