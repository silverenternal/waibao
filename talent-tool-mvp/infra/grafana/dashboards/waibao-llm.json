{
  "title": "Waibao LLM",
  "uid": "waibao-llm",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["waibao", "llm"],
  "panels": [
    {
      "id": 1,
      "title": "p50 latency",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (provider, model, le) (rate(provider_call_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, model, le) (rate(provider_call_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Calls per provider/model",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum by (provider, model) (rate(provider_calls_total[5m]))",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ]
    }
  ]
}