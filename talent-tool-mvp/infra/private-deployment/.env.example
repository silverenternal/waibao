# ============================================================
# v7.0 T3003 私有化部署 .env 模板
#
# 用法:
#   cp infra/private-deployment/.env.example \
#      infra/private-deployment/.env
#   vim infra/private-deployment/.env
#   docker compose -f infra/private-deployment/docker-compose.yml up -d
# ============================================================

# -------- 域名 / TLS --------
PRIMARY_DOMAIN=hire.example.com

# -------- Supabase / Postgres --------
POSTGRES_PASSWORD=change-me-32-chars-min
SUPABASE_JWT_SECRET=replace-with-`openssl rand -base64 32`
SUPABASE_ANON_KEY=replace-with-`openssl rand -base64 32`
SUPABASE_SERVICE_KEY=replace-with-`openssl rand -base64 32`

# -------- 内部 secrets --------
SECRET_KEY=replace-with-`openssl rand -base64 48`
JWT_SECRET=replace-with-`openssl rand -base64 48`

# -------- LLM (至少配一个) --------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=

# -------- 邮件 / 对象存储 --------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# -------- 第三方 (可选,私有化可全留空) --------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -------- 监控 --------
GRAFANA_PASSWORD=admin

# -------- 白标 (可在 admin UI 修改) --------
WHITELABEL_TENANT_ID=default
WHITELABEL_PRODUCT_NAME=Acme Talent
WHITELABEL_PRIMARY_COLOR=#2563EB
WHITELABEL_LOGO_URL=