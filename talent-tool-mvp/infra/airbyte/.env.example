# T2801 — Airbyte OSS
AIRBYTE_VERSION=0.50.33

# Postgres 元数据库
POSTGRES_USER=airbyte
POSTGRES_PASSWORD=airbyte_pass
POSTGRES_DB=airbyte

# MinIO (Airbyte 内部 S3, 存 sync 中间数据)
MINIO_USER=minio_user
MINIO_PASSWORD=minio_pass

# 跨容器 DNS
DATABASE_URL=jdbc:postgresql://airbyte-db:5432/airbyte
CONFIG_DATABASE_URL=jdbc:postgresql://airbyte-db:5432/airbyte
RUN_DATABASE_URL=jdbc:postgresql://airbyte-db:5432/airbyte
JOB_DATABASE_URL=jdbc:postgresql://airbyte-db:5432/airbyte
INTERNAL_API_HOST=airbyte-server
