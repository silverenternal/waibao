# =============================================================================
# Waibao v4.0 真实供应商配置模板
# =============================================================================
#
# 使用方法:
#   1. cp backend/config/.env.example backend/.env
#   2. 按下方注释逐项填入真实凭证
#   3. 设置 PROVIDER_MODE=real (默认 mock — 全部走离线模拟数据)
#   4. docs/REAL_API_SETUP.md  完整申请步骤 + 配额说明
#
# 字段约定:
#   - 留空 = 使用 mock 兜底 (开发/测试默认)
#   - PROVIDER_MODE=real + 关键 key 缺失 = 启动时 warn,不阻断
#   - PROVIDER_MODE=strict + 关键 key 缺失 = 启动失败
#
# 安全提示:
#   - .env 已加入 .gitignore,严禁提交
#   - 生产环境使用 Vault / AWS Secrets Manager 注入
#   - key 轮换时同步更新 backend/scripts/setup_real_keys.sh
# =============================================================================

# -----------------------------------------------------------------------------
# 全局控制
# -----------------------------------------------------------------------------
# PROVIDER_MODE: mock | real | strict
#   mock  → 全部 provider 走本地 mock (默认)
#   real  → 凭证存在时用真实 API,否则降级到 mock
#   strict→ 任一选择的供应商无凭证即启动失败
PROVIDER_MODE=mock

# 单租户默认日预算 (USD),超限熔断
DAILY_BUDGET_USD=50
# 特定租户预算: TENANT_DAILY_BUDGET_USD_<TENANT_ID>=<FLOAT>
# TENANT_DAILY_BUDGET_USD_acme=200

# 重试 / 熔断 / 限流 (高级配置,一般保持默认)
PROVIDER_MAX_RETRIES=3
PROVIDER_BASE_DELAY=1.0
PROVIDER_CIRCUIT_THRESHOLD=5
PROVIDER_CIRCUIT_WINDOW=60
PROVIDER_RATE_PER_SEC=10
PROVIDER_BURST=20

# 监控 / 告警 (可选)
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# =============================================================================
# 1. LLM (大语言模型)
# =============================================================================
# LLM_PROVIDER: openai | anthropic | deepseek | zhipu | tongyi | moonshot | mock
LLM_PROVIDER=mock
# LLM_DEFAULT_MODEL=gpt-4o-mini
# LLM_FALLBACK=anthropic   # 主供应商失败时自动降级

# -----------------------------------------------------------------------------
# 1.1 OpenAI  ──  https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
# 申请 URL:  https://platform.openai.com/api-keys
# 计费:      预付费 (Pay-as-you-go),按 token 计费,需绑定信用卡
# 限流:      Tier 1 免费 3 RPM / 200 RPD;Tier 1 付费 60 RPM / 10K TPM
#            Tier 4 (500 美元消费后) 10K RPM / 30K TPM
# 配额:      单 key 月度无上限,按用量计费,典型 $5 即可跑通测试
# 模型:      gpt-4o / gpt-4o-mini / gpt-4-turbo / o1 / o1-mini
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1  (中转可改 Azure / 国内代理)

# -----------------------------------------------------------------------------
# 1.2 Anthropic Claude  ──  https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
# 申请 URL:  https://console.anthropic.com/settings/keys
# 计费:      预付费,按 token 计费
# 限流:      Tier 1 50 RPM;Tier 2 (40 美元消费后) 1000 RPM
# 配额:      无月度上限,按用量计费
# 模型:      claude-3-5-sonnet-latest / claude-3-5-haiku-latest / claude-3-opus
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# 1.3 DeepSeek  ──  https://platform.deepseek.com/api_keys
# -----------------------------------------------------------------------------
# 申请 URL:  https://platform.deepseek.com/api_keys
# 计费:      预付费充值,余额 1 元起
# 限流:      免费 60 RPM / 1K TPM;充值后无严格限流
# 配额:      deepseek-chat ¥1/M tokens (cache miss),deepseek-reasoner ¥4/M
# 模型:      deepseek-chat / deepseek-reasoner / deepseek-coder
# 兼容:      OpenAI 协议 (base_url=https://api.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# -----------------------------------------------------------------------------
# 1.4 智谱 GLM  ──  https://bigmodel.cn/console/overview
# -----------------------------------------------------------------------------
# 申请 URL:  https://bigmodel.cn/console/apikey  (实名 + 绑卡)
# 计费:      资源包 + 按量,新人送 2000 万 tokens (GLM-4-Flash)
# 限流:      GLM-4-Flash 200 RPM;GLM-4-Plus 60 RPM
# 配额:      GLM-4-Flash ¥0.1/M (input = output),GLM-4-Plus ¥50/M
# 模型:      glm-4-flash / glm-4-air / glm-4-plus / glm-4-long
# 兼容:      OpenAI 协议 (base_url=https://open.bigmodel.cn/api/paas/v4)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# -----------------------------------------------------------------------------
# (辅助) 通义千问 DashScope / Moonshot Kimi
# -----------------------------------------------------------------------------
# 通义千问:  https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TONGYI_API_KEY=
# Moonshot Kimi:  https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# =============================================================================
# 2. Embedding (文本向量化)
# =============================================================================
# EMBEDDING_PROVIDER: openai | zhipu | tongyi | mock
EMBEDDING_PROVIDER=mock

# 2.1 OpenAI Embedding  ── 复用 OPENAI_API_KEY
# 申请 URL:  https://platform.openai.com/api-keys (同上)
# 计费:      text-embedding-3-small $0.02/M,3-large $0.13/M
# 限流:      同 OpenAI 主账号 (60 RPM)
# 维度:      small=1536, large=3072
# OPENAI_API_KEY=<已填>

# 2.2 智谱 Embedding-2  ── 复用 ZHIPU_API_KEY
# 申请 URL:  https://bigmodel.cn/console/apikey (同上)
# 计费:      embedding-2 ¥0.5/M tokens,新人送免费额度
# 限流:      默认 60 RPM,可申请提额
# 维度:      1024
# ZHIPU_API_KEY=<已填>

# =============================================================================
# 3. OCR (光学字符识别)
# =============================================================================
# OCR_PROVIDER: paddle | tencent | baidu | aliyun | mock
# v11.0 默认 paddle —— 本地 PaddleOCR 推理,简历/资质数据不出甲方环境。
OCR_PROVIDER=paddle

# 3.0 PaddleOCR (本地 OCR,推荐生产用,见 docker-compose.local.yml) ---------
# 模型目录 (预下载权重,离线复用);空 = paddleocr 默认缓存
PADDLE_OCR_MODEL_DIR=
# 语言: ch (中英文,默认) | en (纯英文)
PADDLE_OCR_LANG=ch
# GPU 开关 (本地 CPU 默认 false)
PADDLE_OCR_USE_GPU=false
PADDLE_OCR_USE_ANGLE_CLS=true

# -----------------------------------------------------------------------------
# 3.1 腾讯云 OCR  ──  https://console.cloud.tencent.com/cam/capi
# -----------------------------------------------------------------------------
# 申请 URL:  https://console.cloud.tencent.com/cam/capi  创建 SecretId/SecretKey
#           再到 https://console.cloud.tencent.com/ocr  开通 OCR 服务
# 计费:      按次计费,GeneralBasicOCR ¥0.15/次,通用手写体 ¥0.3/次
# 限流:      默认 100 QPS,可提工单调整
# 配额:      新用户 1000 次免费额度
# 接口:      GeneralBasicOCR / GeneralAccurateOCR / SealOCR
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou

# -----------------------------------------------------------------------------
# 3.2 百度 OCR  ──  https://console.bce.baidu.com/ai/#/ai/ocr/app/list
# -----------------------------------------------------------------------------
# 申请 URL:  https://console.bce.baidu.com/ai/#/ai/ocr/app/list
#           创建应用 → 获取 API Key + Secret Key
# 计费:      按次计费,通用文字识别 ¥0.005/次 (千次包 ¥4.5)
# 限流:      默认 10 QPS,可付费提额
# 配额:      新用户每天 1000 次免费调用
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# =============================================================================
# 4. STT (语音转文字)
# =============================================================================
# STT_PROVIDER: whisper | aliyun | mock
STT_PROVIDER=mock

# -----------------------------------------------------------------------------
# 4.1 OpenAI Whisper  ──  https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
# 申请 URL:  https://platform.openai.com/api-keys (复用 OpenAI 账号)
# 计费:      whisper-1 $0.006/分钟 (≈ ¥0.04/分钟)
# 限流:      50 RPM (按请求),单文件上限 25 MB
# 配额:      无月度上限,按用量计费
# 模型:      whisper-1 (多语种,支持 zh/en/ja 等 99 种)
# OPENAI_API_KEY=<已填>

# (辅助) 阿里云一句话识别
# 申请:  https://nls-portal.console.aliyun.com/applications
ALIYUN_ASR_APP_KEY=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# =============================================================================
# 5. Notify (通知渠道)
# =============================================================================
# 每个 channel 单独开关: NOTIFY_<CHANNEL>_ENABLED=true
NOTIFY_SMTP_ENABLED=false
NOTIFY_DINGTALK_ENABLED=false
NOTIFY_FEISHU_ENABLED=false
NOTIFY_WECOM_ENABLED=false
NOTIFY_WEBHOOK_ENABLED=false

# -----------------------------------------------------------------------------
# 5.1 SendGrid / SMTP
# -----------------------------------------------------------------------------
# SendGrid 申请 URL:  https://app.sendgrid.com/settings/api_keys
#   计费:  免费版 100 封/天,Essentials $20/月 50K 封
#   限流:  免费 100/day;付费 100K/小时
#   配额:  按 plan
#   HOST:  smtp.sendgrid.net / PORT 587 / 用 apikey 作 username
#
# 自建 SMTP: 用公司邮件服务器即可
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
# SMTP_FROM 必须为已验证的发件人
# SendGrid Sender: https://app.sendgrid.com/settings/senders
SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# 6. Lookup (企业信息查询)
# =============================================================================
# LOOKUP_PROVIDER: tianyancha | qichacha | mock
LOOKUP_PROVIDER=mock

# -----------------------------------------------------------------------------
# 6.1 天眼查 OpenAPI  ──  https://open.tianyancha.com/console
# -----------------------------------------------------------------------------
# 申请 URL:  https://open.tianyancha.com/console  → 我的应用 → 创建应用
#           审核通过后获取 api_key (Authorization 头)
# 计费:      按调用次数,¥0.05 ~ ¥0.5/次 (按接口)
# 限流:      默认 100 QPS,可付费提额
# 配额:      包年套餐 ¥2K 起,含 5000 ~ 20000 次调用
# 接口:      /ic/baseinfo/2.0 (企业基本信息) /ic/search/2.0 (关键字搜索)
TIANYANCHA_API_KEY=
TIANYANCHA_BASE_URL=https://open.tianyancha.com/services/open/ic/baseinfo/2.0

# =============================================================================
# 7. JobMarket (招聘市场数据)
# =============================================================================
# JOB_MARKET_PROVIDER: boss | lagou | adzuna | linkedin | mock
JOB_MARKET_PROVIDER=mock

# -----------------------------------------------------------------------------
# 7.1 Boss直聘 OpenAPI  ──  https://www.zhipin.com/api/
# -----------------------------------------------------------------------------
# 申请 URL:  https://www.zhipin.com/api/  企业账号 → 申请 OpenAPI
#           需企业资质 + AppKey,沙箱数据有限
# 计费:      企业版定价 (按调用量阶梯),通常 ¥5K ~ ¥50K/年
# 限流:      默认 60 QPS,可联系销售调整
# 配额:      按购买套餐 (5K / 20K / 100K 次)
# 鉴权:      Header `X-App-Key: <app_key>`
JOB_MARKET_BOSS_APP_KEY=
JOB_MARKET_BOSS_BASE_URL=https://openapi.zhipin.com/v1
JOB_MARKET_BOSS_TIMEOUT=8.0

# =============================================================================
# 8. Video (视频面试)
# =============================================================================
# VIDEO_INTERVIEW_PROVIDER: zoom | tencent_meeting | mock
VIDEO_INTERVIEW_PROVIDER=mock
ZOOM_PROVIDER=false

# -----------------------------------------------------------------------------
# 8.1 Zoom Server-to-Server OAuth  ──  https://marketplace.zoom.us/
# -----------------------------------------------------------------------------
# 申请 URL:  https://marketplace.zoom.us/develop/create  → Server-to-Server OAuth
#           创建应用 → 获得 Account ID / Client ID / Client Secret
#           必须启用 scopes: meeting:write, recording:read, user:read
# 计费:      Pro 许可证 $15/月/host;API 调用本身免费
# 限流:      Light 100 RPD,Medium 2500 RPD,Large 7500 RPD (按账号类型)
# 配额:      受 license 用户数限制
# 接口:      POST /users/me/meetings (创建会议), DELETE /meetings/{id}
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_USER_ID=me
ZOOM_API_BASE=https://api.zoom.us/v2

# =============================================================================
# 9. Billing (支付)
# =============================================================================
# PAYMENT_PROVIDER: stripe | wechat_pay | mock
PAYMENT_PROVIDER=mock

# -----------------------------------------------------------------------------
# 9.1 Stripe  ──  https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
# 申请 URL:  https://dashboard.stripe.com/register  (邮箱 + 信用卡)
#           然后 https://dashboard.stripe.com/apikeys  拿 secret_key
#           测试用 https://dashboard.stripe.com/test/apikeys (sk_test_...)
# 计费:      标准费率 2.9% + $0.3/笔,无月费
# 限流:      默认 100 RPS,Stripe 会按需调整
# 配额:      无硬上限
# Webhook 签名密钥: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# 同步配置 webhook (T1405):
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# 10. Webhook (群机器人)
# =============================================================================
# 每个 webhook 单独通过 ENABLE 控制,不需要 key 池

# -----------------------------------------------------------------------------
# 10.1 钉钉群机器人  ──  https://open.dingtalk.com/document/orgapp/custom-robot-access
# -----------------------------------------------------------------------------
# 申请 URL:
#   1. PC 钉钉 → 目标群 → 群设置 → 智能群助手 → 添加机器人 → 自定义
#   2. 勾选"加签"→ 复制 webhook + secret
# 限流:    每分钟 20 条 (安全设置可放宽到 600 RPM)
# 配额:    无月度上限
# 安全:    强烈建议启用 "加签" (HMAC-SHA256),IP 白名单二选一
DINGTALK_WEBHOOK=
# DINGTALK_SECRET=  ← 加签密钥,留空 = 不签名 (会被限流到 20 RPM)
DINGTALK_SECRET=

# -----------------------------------------------------------------------------
# 10.2 飞书群机器人  ──  https://open.feishu.cn/document/client-docs/bot-v3/add-custom-bot
# -----------------------------------------------------------------------------
# 申请 URL:
#   1. PC 飞书 → 目标群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人
#   2. 勾选"签名校验"→ 复制 webhook + secret
# 限流:    100 RPM (单机器人),5 条/秒
# 配额:    无月度上限
# 安全:    必须开启"签名校验"
FEISHU_WEBHOOK=
FEISHU_SECRET=

# 企业微信 (备选)
# 申请: https://work.weixin.qq.com/api/doc/90000/90136/91770
WECOM_WEBHOOK=

# 自定义 Webhook (通用 HTTP)
WEBHOOK_URL=
WEBHOOK_METHOD=POST
WEBHOOK_TEMPLATE=json
# 多行 header: 每行 "Key: Value"
WEBHOOK_HEADERS=

# =============================================================================
# 11. ATS (招聘系统对接) — 可选,T1701 不强制
# =============================================================================
# ATS_PROVIDER: bullhorn | greenhouse | mock
ATS_PROVIDER=mock
BULLHORN_API_URL=
BULLHORN_CLIENT_ID=
BULLHORN_CLIENT_SECRET=

# =============================================================================
# 12. BackgroundCheck (背调) — 可选
# =============================================================================
# BACK_CHECK_PROVIDER: checkr | mock
BACK_CHECK_PROVIDER=mock
CHECKR_API_KEY=

# =============================================================================
# 13. Assessment (测评) — 可选
# =============================================================================
# ASSESSMENT_PROVIDER: pymetrics | mock
ASSESSMENT_PROVIDER=mock
PYMETRICS_API_KEY=

# =============================================================================
# 14. Vision (多模态视觉) — 可选
# =============================================================================
# VISION_PROVIDER: gpt4v | qwen_vl | mock
VISION_PROVIDER=mock
# 复用上述 OpenAI / 智谱 / 通义 key

# =============================================================================
# 开发 / 测试 标记
# =============================================================================
ENV=development
LOG_LEVEL=INFO
ENABLE_REAL_API_TESTS=false   # CI 中默认 false,本地填 true 后 pytest -m real_api

# 数据库 (本地 dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# JWT / 加密
SUPABASE_JWT_SECRET=
PII_ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Region / Locale
REGION=local
DATA_RESIDENCY=local
DEFAULT_LOCALE=zh