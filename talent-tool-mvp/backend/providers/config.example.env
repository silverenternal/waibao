# =============================================================================
# Waibao 外部供应商配置 (复制为 .env 并填写真实值)
# =============================================================================
# 切换供应商只需修改下列 ENV 变量,无需改代码。
# 不填或填 "mock" 时,registry 自动 fallback 到 providers.mock.MockProvider.

# ----------------------------- 全局 ------------------------------------------
# 单租户默认日预算 (USD)
DAILY_BUDGET_USD=50
# 特定租户预算: TENANT_DAILY_BUDGET_USD_<TENANT>=<FLOAT>
# TENANT_DAILY_BUDGET_USD_acme=200

# 重试 / 熔断 / 限流 (高级配置)
PROVIDER_MAX_RETRIES=3
PROVIDER_BASE_DELAY=1.0
PROVIDER_CIRCUIT_THRESHOLD=5
PROVIDER_CIRCUIT_WINDOW=60
PROVIDER_RATE_PER_SEC=10
PROVIDER_BURST=20

# ----------------------------- LLM -------------------------------------------
# LLM_PROVIDER: openai | anthropic | deepseek | zhipu | tongyi | moonshot | mock
LLM_PROVIDER=mock
# LLM_DEFAULT_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=

# DeepSeek (OpenAI 兼容)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 智谱 GLM (OpenAI 兼容)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 通义千问 (DashScope OpenAI 兼容)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TONGYI_API_KEY=

# 月之暗面 Kimi (OpenAI 兼容)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ----------------------------- Embedding -------------------------------------
# EMBEDDING_PROVIDER: openai | zhipu | tongyi | mock
EMBEDDING_PROVIDER=mock
# OpenAI text-embedding-3 (复用 OPENAI_API_KEY)
# ZHIPU embedding-2
# TONGYI text-embedding-v3 (复用 DASHSCOPE_API_KEY)

# ----------------------------- Vision (多模态) -------------------------------
# VISION_PROVIDER: gpt4v | qwen_vl | mock
VISION_PROVIDER=mock

# ----------------------------- OCR -------------------------------------------
# OCR_PROVIDER: tencent | baidu | aliyun | gpt4v | mock
OCR_PROVIDER=mock

# 腾讯云 (GeneralBasicOCR)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_OCR_REGION=ap-guangzhou

# 百度
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 阿里云读光 OCR
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# ----------------------------- STT -------------------------------------------
# STT_PROVIDER: whisper | aliyun | mock
STT_PROVIDER=mock

# OpenAI Whisper (复用 OPENAI_API_KEY)
# 阿里云一句话识别
ALIYUN_ASR_APP_KEY=

# ----------------------------- Notify ---------------------------------------
# 每个 channel 单独开关: NOTIFY_<CHANNEL>_ENABLED=true
NOTIFY_SMTP_ENABLED=false
NOTIFY_DINGTALK_ENABLED=false
NOTIFY_FEISHU_ENABLED=false
NOTIFY_WECOM_ENABLED=false
NOTIFY_WEBHOOK_ENABLED=false

# SMTP / SendGrid
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# 钉钉
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 飞书
FEISHU_WEBHOOK=
FEISHU_SECRET=

# 企业微信
WECOM_WEBHOOK=

# 自定义 Webhook
WEBHOOK_URL=
WEBHOOK_METHOD=POST
WEBHOOK_TEMPLATE=json
# 多行 header: 每行 "Key: Value"
WEBHOOK_HEADERS=

# ----------------------------- CompanyLookup ---------------------------------
# LOOKUP_PROVIDER: tianyancha | qichacha | mock
LOOKUP_PROVIDER=mock

# 天眼查
TIANYANCHA_API_KEY=
TIANYANCHA_BASE_URL=https://open.tianyancha.com/services/open/ic/baseinfo/2.0

# 启信宝
QICHACHA_APP_KEY=
QICHACHA_APP_SECRET=
QICHACHA_BASE_URL=https://api.qichacha.com/ECIV4/GetBasicDetailsByName
