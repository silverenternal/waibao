# Cube.js BI server env (T2802)

# Auth
CUBEJS_API_SECRET=waibao-bi-dev-secret-CHANGE-ME-IN-PROD

# Listen
CUBEJS_PORT=4000

# Primary OLTP DB (fallback)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=waibao
PG_USER=postgres
PG_PASSWORD=postgres
PG_SSL=false

# Analytics warehouse (preferred source for BI)
WAREHOUSE_HOST=localhost
WAREHOUSE_PORT=5432
WAREHOUSE_DB=waibao_warehouse
WAREHOUSE_USER=warehouse
WAREHOUSE_PASSWORD=warehouse
WAREHOUSE_SSL=false

# CORS
CUBEJS_CORS_ORIGIN=*
