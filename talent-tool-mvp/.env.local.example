# =============================================================================
# .env.local.example — v11.0 本地全离线部署完整配置模板
#
# 第三方大模型数据完全不允许离开甲方环境 → 本地 Ollama 推理。
# 复制为 .env.local 并按需修改;docker-compose.local.yml 会读取这些变量。
#
# 用法:
#   cp .env.local.example .env.local
#   bash scripts/start_local.sh
# =============================================================================

# ---- 数据库 (PostgreSQL) ---------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=waibao
# 后端用容器内服务名连接;宿主直连用 localhost:5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/waibao

# ---- 缓存 / 限流 / EventBus (Redis) ----------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---- 跨域 (前端同源访问后端) ------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ---- LLM: 本地 Ollama (默认,数据不出网) -----------------------------------
# LLM_PROVIDER 可选: ollama(默认本地) | openai | anthropic | deepseek | zhipu | tongyi | moonshot | mock
LLM_PROVIDER=ollama

# Ollama OpenAI 兼容地址 (provider 内部自动补 /v1)
# docker compose 网络内用 http://ollama:11434;宿主直连用 http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434

# 默认模型 (中文最好)。备选: glm4:9b / llama3.1:8b
OLLAMA_MODEL=qwen2.5:7b-instruct

# ---- OCR: 本地 PaddleOCR (默认,简历/资质数据不出网) -----------------------
# OCR_PROVIDER 可选: paddle(默认本地) | tencent | baidu | aliyun | gpt4v | mock
OCR_PROVIDER=paddle

# PaddleOCR 模型目录 (预下载权重,离线复用);空 = paddleocr 默认缓存
PADDLE_OCR_MODEL_DIR=/models/paddle

# 语言: ch (中英文,默认) | en (纯英文)
PADDLE_OCR_LANG=ch

# 是否启用 GPU (本地 CPU 默认 false)
PADDLE_OCR_USE_GPU=false
PADDLE_OCR_USE_ANGLE_CLS=true

# ---- 本地部署可选: 开发态 mock fallback -----------------------------------
# 仅当显式 LLM_PROVIDER=mock 时,MockLLMProvider 会先尝试 ollama,不通再走启发式。
# 生产默认关闭,避免误用 mock。
# WAIBAO_PROVIDER_MOCK=1
